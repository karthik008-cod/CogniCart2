{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|html))",
      "dest": "/public/$1"
    },
    {
      "src": "/watchlist",
      "dest": "/public/watchlist.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/check-prices",
      "schedule": "0 */6 * * *"
    }
  ]
}